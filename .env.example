# Required for examples/claude-acp-agent.mjs (OpenRouter-backed LLM agent)
OPENROUTER_API_KEY=

# ACL directory service URL (for agent discovery)
ACL_DIRECTORY_URL=http://127.0.0.1:4040

# TLS CA certificate for outbound WSS verification
ACL_TLS_CA_CERT=./.acl/tls/ca.cert.pem

# Contacts store file path
ACL_CONTACTS_FILE=

# Optional local directory fixture for development and tests
ACL_DIRECTORY_FIXTURE=

# Claude ACP agent overrides
ACL_CLAUDE_MODEL=anthropic/claude-sonnet-4
ACL_CLAUDE_SYSTEM=
ACL_CLAUDE_MAX_TOKENS=2048

# Mailbox agent output path
ACL_MAILBOX_FILE=/tmp/acl-mailbox.jsonl
